---
import { Icon } from "astro-icon/components";

const contactData = [
    {
        id: "email",
        title: "Envíanos un correo",
        description: "Estamos a un click",
        link: "mailto:hello@",
        icon: "ri:mail-fill",
    },
    {
        id: "phone",
        title: "Llámanos",
        description: "O escribinos un mensaje",
        link: "https://wa.me/5491162485810",
        icon: "ri:phone-fill",
    },
    {
        id: "location",
        title: "Visítanos",
        description: "En nuestras oficinas",
        link: "calle Buena Vida 4321",
        icon: "ri:map-pin-fill",
    },
];
---

<section
    id="contact"
    class="py-24 bg-slate-900 border-t border-slate-800 relative overflow-hidden reveal"
>
    <!-- Decorative background -->
    <div
        class="absolute inset-0 bg-[radial-gradient(circle_at_bottom_right,var(--tw-gradient-stops))] from-indigo-900/20 via-slate-900 to-slate-900 -z-10"
    >
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid lg:grid-cols-2 gap-16">
            <div>
                <div
                    class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-indigo-500/10 border border-indigo-500/20 text-indigo-400 text-sm font-semibold tracking-wide uppercase mb-6"
                >
                    Contactanos
                </div>
                <h2 class="text-3xl md:text-5xl font-bold mb-6 reveal">
                    Hablemos de tu próximo <span
                        class="text-transparent bg-clip-text bg-linear-to-r from-primary to-accent"
                        >proyecto.</span
                    >
                </h2>
                <p
                    class="text-lg text-slate-400 mb-10 leading-relaxed max-w-lg"
                >
                    Ya sea que tengas una visión clara o solo una idea
                    aproximada, estamos aquí para ayudarte a darle vida.
                    Completa el formulario y te responderemos en menos de 24
                    horas.
                </p>

                <div class="space-y-8">
                    {
                        contactData.map((contact) => (
                            <div class="flex items-start gap-4 group">
                                <div class="w-12 h-12 rounded-xl bg-indigo-500/10 flex items-center justify-center shrink-0 group-hover:bg-indigo-500/20 transition-colors">
                                    <Icon
                                        name={contact.icon}
                                        class="w-6 h-6 text-indigo-400"
                                    />
                                </div>
                                <div>
                                    <h3 class="text-white font-medium mb-1 text-lg">
                                        {contact.title}
                                    </h3>
                                    {contact.id === "location" ? (
                                        <p class="text-slate-400">
                                            {contact.description}
                                        </p>
                                    ) : (
                                        <a
                                            href={contact.link}
                                            class="text-slate-400 hover:text-indigo-400 transition-colors"
                                        >
                                            {contact.description}
                                        </a>
                                    )}
                                </div>
                            </div>
                        ))
                    }
                </div>
            </div>

            <div
                class="bg-slate-950 p-8 md:p-10 rounded-3xl border border-slate-800 shadow-2xl relative"
            >
                <!-- Inner glow -->
                <div
                    class="absolute -top-24 -right-24 w-48 h-48 bg-indigo-600/30 rounded-full blur-3xl pointer-events-none"
                >
                </div>

                <form action="#" method="POST" class="relative z-10 space-y-6">
                    <div class="grid sm:grid-cols-2 gap-6">
                        <div class="space-y-2">
                            <label
                                for="first-name"
                                class="block text-sm font-medium text-slate-300"
                                >Nombre</label
                            >
                            <input
                                type="text"
                                name="first-name"
                                id="first-name"
                                required
                                class="w-full bg-slate-900 border border-slate-700 rounded-xl px-4 py-3 text-white placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition-all"
                                placeholder="John"
                            />
                        </div>
                        <div class="space-y-2">
                            <label
                                for="last-name"
                                class="block text-sm font-medium text-slate-300"
                                >Apellido</label
                            >
                            <input
                                type="text"
                                name="last-name"
                                id="last-name"
                                required
                                class="w-full bg-slate-900 border border-slate-700 rounded-xl px-4 py-3 text-white placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition-all"
                                placeholder="Doe"
                            />
                        </div>
                    </div>

                    <div class="space-y-2">
                        <label
                            for="email"
                            class="block text-sm font-medium text-slate-300"
                            >Email</label
                        >
                        <input
                            type="email"
                            name="email"
                            id="email"
                            required
                            class="w-full bg-slate-900 border border-slate-700 rounded-xl px-4 py-3 text-white placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition-all"
                            placeholder="john@company.com"
                        />
                    </div>

                    <div class="space-y-2">
                        <label
                            for="budget"
                            class="block text-sm font-medium text-slate-300"
                            >Presupuesto</label
                        >
                        <div class="relative">
                            <select
                                id="budget"
                                name="budget"
                                required
                                class="w-full bg-slate-900 border border-slate-700 rounded-xl px-4 py-3 text-white focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition-all appearance-none"
                            >
                                <option value="" disabled selected
                                    >Selecciona un rango</option
                                >
                                <option value="5k-10k">$5k - $10k</option>
                                <option value="10k-25k">$10k - $25k</option>
                                <option value="25k-50k">$25k - $50k</option>
                                <option value="50k+">$50k+</option>
                            </select>
                            <div
                                class="absolute inset-y-0 right-0 flex items-center px-4 pointer-events-none"
                            >
                                <svg
                                    class="w-4 h-4 text-slate-400"
                                    fill="none"
                                    stroke="currentColor"
                                    viewBox="0 0 24 24"
                                    ><path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M19 9l-7 7-7-7"></path></svg
                                >
                            </div>
                        </div>
                    </div>

                    <div class="space-y-2">
                        <label
                            for="message"
                            class="block text-sm font-medium text-slate-300"
                            >Detalles del proyecto</label
                        >
                        <textarea
                            id="message"
                            name="message"
                            rows="4"
                            required
                            class="w-full bg-slate-900 border border-slate-700 rounded-xl px-4 py-3 text-white placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition-all resize-none"
                            placeholder="Tell us about your goals, timeline, and requirements..."
                        ></textarea>
                    </div>

                    <button
                        type="submit"
                        class="w-full flex items-center justify-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white px-8 py-4 rounded-xl text-lg font-medium transition-all shadow-[0_0_20px_rgba(79,70,229,0.3)] hover:shadow-[0_0_30px_rgba(79,70,229,0.5)] mt-4"
                    >
                        Enviar Mensaje
                        <Icon name="ri:send-plane-fill" class="w-5 h-5" />
                    </button>

                    <p class="text-sm text-white0 text-center mt-4">
                        Al enviar este formulario, aceptas nuestra política de
                        privacidad.
                    </p>
                </form>
            </div>
        </div>
    </div>
</section>

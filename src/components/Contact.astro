---
import { Icon } from "astro-icon/components";
import Badge from "./ui/Badge.astro";
import GradientText from "./ui/GradientText.astro";

const contactData = [
  {
    id: "email",
    title: "Envíanos un correo",
    description: "hello@dvlop.com",
    link: "mailto:hello@dvlop.com",
    icon: "ri:mail-fill",
  },
  {
    id: "phone",
    title: "Llámanos",
    description: "1162485810",
    link: "https://wa.me/5491162485810",
    icon: "ri:phone-fill",
  },
  {
    id: "location",
    title: "Visítanos",
    description: "calle Buena Vida 4321",
    icon: "ri:map-pin-fill",
  },
];
---

<section
  id="contact"
  class="py-24 bg-void border-t border-primary/10 relative overflow-hidden reveal"
>
  <div
    class="absolute inset-0 bg-[radial-gradient(circle_at_bottom_right,var(--tw-gradient-stops))] from-primary/20 via-surface to-surface -z-10"
  >
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-16">
      <div>
        <Badge text="Contactanos" variant="secondary" />
        <h2 class="text-3xl md:text-5xl font-bold mb-6 reveal font-heading">
          ¿Necesitas llevar tu negocio a <GradientText>Google?</GradientText>
        </h2>
        <p class="text-lg text-muted mb-10 leading-relaxed max-w-lg font-mono">
          Ya sea que tengas una visión clara o solo una idea aproximada, estamos
          aquí para ayudarte a darle vida. Completa el formulario y te
          responderemos en menos de 24 horas.
        </p>

        <div class="space-y-8">
          {
            contactData.map((contact) => (
              <div class="flex items-start gap-4 group">
                <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center shrink-0 group-hover:bg-primary/20 transition-colors">
                  <Icon name={contact.icon} class="w-6 h-6 text-primary" />
                </div>
                <div>
                  <h3 class="text-ivory font-medium mb-1 text-lg">
                    {contact.title}
                  </h3>
                  {contact.id === "location" ? (
                    <p class="text-muted font-mono">{contact.description}</p>
                  ) : (
                    <a
                      href={contact.link}
                      class="text-muted font-mono hover:text-primary transition-colors"
                    >
                      {contact.description}
                    </a>
                  )}
                </div>
              </div>
            ))
          }
        </div>
      </div>

      <div
        class="bg-surface p-8 md:p-10 rounded-3xl border border-primary/10 shadow-2xl relative"
      >
        <div
          class="absolute -top-24 -right-24 w-48 h-48 bg-primary/30 rounded-full blur-3xl pointer-events-none"
        >
        </div>

        <form action="#" method="POST" class="relative z-10 space-y-6">
          <div class="grid sm:grid-cols-2 gap-6">
            <div class="space-y-2">
              <label
                for="first-name"
                class="block text-sm font-medium text-ivory/60">Nombre</label
              >
              <input
                type="text"
                name="first-name"
                id="first-name"
                required
                class="w-full bg-void border border-primary/10 rounded-xl px-4 py-3 text-ivory placeholder-muted focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-all placeholder:font-mono"
                placeholder="John"
              />
            </div>
            <div class="space-y-2">
              <label
                for="last-name"
                class="block text-sm font-medium text-ivory/60">Apellido</label
              >
              <input
                type="text"
                name="last-name"
                id="last-name"
                required
                class="w-full bg-void border border-primary/10 rounded-xl px-4 py-3 text-ivory placeholder-muted focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-all placeholder:font-mono"
                placeholder="Doe"
              />
            </div>
          </div>

          <div class="space-y-2">
            <label for="email" class="block text-sm font-medium text-ivory/60"
              >Email</label
            >
            <input
              type="email"
              name="email"
              id="email"
              required
              class="w-full bg-void border border-primary/10 rounded-xl px-4 py-3 text-ivory placeholder-muted focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-all placeholder:font-mono"
              placeholder="john@company.com"
            />
          </div>

          <div class="space-y-2">
            <label for="budget" class="block text-sm font-medium text-ivory/60"
              >Presupuesto</label
            >
            <div class="relative">
              <select
                id="budget"
                name="budget"
                required
                class="w-full bg-void border border-primary/10 rounded-xl px-4 py-3 text-ivory focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-all appearance-none font-mono"
              >
                <option value="" disabled selected>Selecciona un rango</option>
                <option value="5k-10k">$100k - $300k</option>
                <option value="10k-25k">$300k - $500k</option>
                <option value="25k-50k">$500k - $950k</option>
                <option value="50k+">$950k+</option>
              </select>
              <div
                class="absolute inset-y-0 right-0 flex items-center px-4 pointer-events-none"
              >
                <svg
                  class="w-4 h-4 text-muted"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                  ><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M19 9l-7 7-7-7"></path></svg
                >
              </div>
            </div>
          </div>

          <div class="space-y-2">
            <label for="message" class="block text-sm font-medium text-ivory/60"
              >Detalles del proyecto</label
            >
            <textarea
              id="message"
              name="message"
              rows="4"
              required
              class="w-full bg-void border border-primary/10 rounded-xl px-4 py-3 text-ivory placeholder-muted focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-all resize-none placeholder:font-mono"
              placeholder="Tell us about your goals, timeline, and requirements..."
            ></textarea>
          </div>

          <button
            type="submit"
            class="w-full flex items-center justify-center gap-2 bg-cta-violet text-ivory px-8 py-4 rounded-xl text-lg font-medium transition-all shadow-[0_0_20px_rgba(234,88,12,0.3)] hover:shadow-[0_0_30px_rgba(234,88,12,0.5)] mt-4"
          >
            Enviar Mensaje
            <Icon name="ri:send-plane-fill" class="w-5 h-5" />
          </button>

          <p class="text-sm text-muted text-center mt-4 font-mono">
            Al enviar este formulario, aceptas nuestra política de privacidad.
          </p>
        </form>
      </div>
    </div>
  </div>
</section>

---
import { Icon } from "astro-icon/components";
import { siteConfig, footerLinks } from "../data/site";

const currentYear = new Date().getFullYear();
---

<footer class="bg-void pt-20 pb-10 border-t border-primary/10 reveal">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12 md:gap-8 mb-16">
      <div class="col-span-1 md:col-span-2">
        <a href="/" class="flex items-center gap-2 mb-6 w-fit">
          <p
            class="font-mono font-extrabold text-2xl tracking-tight text-ivory"
          >
            LUCAS<span
              class="bg-linear-to-r from-primary to-accent text-transparent bg-clip-text"
              >＜DEV∕＞</span
            >
          </p>
        </a>
        <p class="text-ivory/60 max-w-sm leading-relaxed mb-8 font-mono">
          {siteConfig.description}
        </p>
        <div class="flex items-center gap-4">
          {
            siteConfig.socials.map((social) => (
              <a
                href={social.href}
                aria-label={social.name}
                class="w-10 h-10 rounded-full bg-surface border border-primary/10 flex items-center justify-center text-muted hover:text-accent hover:border-accent/30 hover:bg-accent/10 transition-all group"
              >
                <Icon
                  name={social.icon}
                  class="w-5 h-5 group-hover:scale-110 transition-transform"
                />
              </a>
            ))
          }
        </div>
      </div>

      <div>
        <h3
          class="text-ivory font-bold mb-6 tracking-wide uppercase text-sm font-heading"
        >
          Mapa del Sitio
        </h3>
        <ul class="space-y-4">
          {
            footerLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-ivory/60 hover:text-primary transition-colors font-medium"
                >
                  {link.name}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div>
        <h3
          class="text-ivory font-bold mb-6 tracking-wide uppercase text-sm font-heading"
        >
          Ubicación
        </h3>
        <ul class="space-y-4 font-mono">
          <li class="text-ivory/60">
            {siteConfig.address[0]}<br />
            {siteConfig.address[1]}
          </li>
          <li>
            <a
              href={`mailto:${siteConfig.email}`}
              class="text-ivory/60 hover:text-primary transition-colors"
            >
              {siteConfig.email}
            </a>
          </li>
          <li>
            <a
              href={`tel:${siteConfig.phone}`}
              class="text-ivory/60 hover:text-primary transition-colors"
            >
              {siteConfig.phone}
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div
      class="pt-8 border-t border-primary/10 flex flex-col md:flex-row items-center justify-between gap-4"
    >
      <p class="text-muted text-sm">
        &copy; {currentYear} LUCAS＜DEV∕＞ &trade;. Todos los derechos reservados.
      </p>
      <div class="flex items-center gap-6 text-sm text-muted">
        <a href="/privacy-policy" class="hover:text-ivory transition-colors"
          >Política de Privacidad</a
        >
        <a href="/terms-of-service" class="hover:text-ivory transition-colors"
          >Términos de Servicio</a
        >
      </div>
    </div>
  </div>
</footer>

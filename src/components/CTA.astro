// CTA Component
---

<section id="contact" class="py-24 relative overflow-hidden reveal">
    <div class="absolute inset-0 bg-indigo-600 -z-10"></div>
    <!-- Decorative background elements -->
    <div class="absolute top-0 right-0 -translate-y-1/2 translate-x-1/3 w-[800px] h-[800px] bg-indigo-600 rounded-full blur-3xl opacity-50 -z-10"></div>
    <div class="absolute bottom-0 left-0 translate-y-1/3 -translate-x-1/3 w-[600px] h-[600px] bg-indigo-800 rounded-full blur-3xl opacity-50 -z-10"></div>
    
    <div class="max-w-4xl mx-auto px-4 text-center">
        <h2 class="text-4xl md:text-5xl font-bold text-white mb-6 reveal">Ready to transform your digital presence?</h2>
        <p class="text-indigo-100 text-xl mb-10 text-balance">Let's build something extraordinary together. Get in touch for a free consultation about your next big idea.</p>
        <a href="mailto:hello@dvlop.agency" class="inline-block bg-white text-indigo-900 hover:bg-slate-50 px-8 py-4 rounded-full font-bold text-lg transition-transform hover:scale-105 shadow-xl">
            Contact Us Today
        </a>

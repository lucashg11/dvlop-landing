---
import { Image } from "astro:assets";
import aboutImage from "../assets/images/profile-3.png";
import Badge from "./ui/Badge.astro";
import GradientText from "./ui/GradientText.astro";
import Button from "./ui/Button.astro";

const features = [
  "+5 años de experiencia",
  "HTML · CSS · JS · Astro · MERN",
  "Sitios entregados en 7 a 10 días",
  "Comunicación directa por WhatsApp",
];
---

<section id="about" class="py-24 bg-void reveal">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <div class="relative">
        <div
          class="absolute inset-0 bg-primary rounded-3xl blur-3xl opacity-20 -z-10"
        >
        </div>
        <Image
          src={aboutImage}
          alt="Our team working together"
          loading="lazy"
          class="rounded-3xl shadow-2xl border border-primary/10 object-cover aspect-square w-full"
        />
        <div
          class="absolute -bottom-6 -right-6 bg-surface border border-primary/10 p-6 rounded-2xl shadow-xl hidden sm:block"
        >
          <div class="text-4xl font-extrabold text-primary mb-1 font-display">
            +5 años
          </div>
          <div class="text-ivory font-medium">De Experiencia</div>
        </div>
      </div>

      <div>
        <Badge text="Sobre mi" variant="secondary" />
        <h2 class="text-3xl md:text-5xl font-bold mb-6 reveal font-heading">
          Hola, soy <GradientText>Lucas</GradientText>.
        </h2>
        <p class="text-lg text-ivory mb-8 leading-relaxed font-mono">
          Soy desarrollador web frontend con más de 5 años de experiencia. Me
          especializo en sitios rápidos, modernos y pensados para negocios
          reales: locales, emprendedores y PyMEs que quieren presencia digital
          que funcione de verdad, no templates genéricos.
        </p>
        <p class="text-lg text-ivory mb-8 leading-relaxed font-mono">
          Trabajo con HTML, CSS, JavaScript, Tailwind CSS y Astro para sitios
          estáticos modernos, y con el stack MERN cuando necesitas algo más
          complejo. Cada proyecto lo trabajo de forma personalizada, con
          comunicación directa y sin intermediarios.
        </p>
        <p class="text-lg text-ivory mb-8 leading-relaxed font-mono">
          Si llegaste hasta acá, probablemente tenés un negocio y querés que más
          gente te encuentre online. Puedo ayudarte con eso.
        </p>

        <div class="space-y-4 mb-10">
          {
            features.map((feature) => (
              <div class="flex items-center gap-3">
                <svg
                  class="w-6 h-6 text-success shrink-0"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
                  />
                </svg>
                <span class="text-ivory font-medium">{feature}</span>
              </div>
            ))
          }
        </div>

        <Button href="#contact" variant="secondary"
          >Contame sobre tu proyecto</Button
        >
      </div>
    </div>
  </div>
</section>

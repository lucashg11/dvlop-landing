---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

export interface Props {
  src: ImageMetadata
  alt: string
  aspect?: string
  loading?: "eager" | "lazy"
  glowColor?: string
  class?: string
  transitionName?: string
}

const {
  src,
  alt,
  aspect = "aspect-4/3",
  loading = "lazy",
  glowColor = "bg-primary",
  class: className = "",
  transitionName,
} = Astro.props;
---

<div class={["relative", className].filter(Boolean).join(" ")}>
  <div
    class:list={["absolute inset-0 rounded-3xl blur-3xl opacity-20 -z-10", glowColor]}
  />
  <div class="overflow-hidden rounded-3xl border border-surface/50 shadow-2xl">
    <Image
      src={src}
      alt={alt}
      loading={loading}
      class:list={[
        "w-full object-cover transform group-hover:scale-105 transition-transform duration-700 ease-out",
        aspect,
      ]}
      {...(transitionName ? { "transition:name": transitionName } : {})}
    />
  </div>
</div>

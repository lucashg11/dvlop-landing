---
import { Image } from "astro:assets";
import { ICONS } from "../../data/icons";
import Button from "../ui/Button.astro";
import GradientText from "../ui/GradientText.astro";
import type { Service } from "../../data/services";

export interface Props {
  services: Service[];
}
const { services } = Astro.props;
---

<main class="pt-32 pb-24">
  <section
    class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center mb-24 reveal"
  >
    <h1
      class="text-5xl md:text-7xl font-extrabold mb-6 reveal font-display"
      transition:name="services-title"
    >
      Lo que <GradientText>ofrezco</GradientText>
    </h1>
    <p class="text-xl text-muted max-w-3xl mx-auto font-mono">
      Cada servicio está diseñado para resolver un problema específico de tu
      negocio. Responsivo, rápido, posicionado en Google. Sin vueltas.
    </p>
  </section>

  <div class="space-y-32">
    {
      services.map((service, index) => {
        const isEven = index % 2 === 0;
        const Icon = ICONS[service.icon];

        return (
          <section
            id={service.id}
            class="scroll-mt-40 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 group reveal"
          >
            <div class="grid lg:grid-cols-2 gap-16 items-center">
              <div class={!isEven ? "lg:order-2" : "lg:order-1"}>
                <div class="inline-flex items-center gap-3 px-4 py-2 rounded-xl bg-primary/10 border border-primary/20 text-primary mb-6 group-hover:bg-primary/20 transition-colors">
                  {Icon && <Icon class="w-5 h-5" />}
                  <span class="font-semibold tracking-wide uppercase text-sm font-heading">
                    {service.title}
                  </span>
                </div>

                <h2 class="text-3xl md:text-4xl font-bold mb-6 group-hover:text-primary transition-colors reveal font-heading">
                  {service.title}
                </h2>
                <p class="text-lg text-muted mb-8 leading-relaxed font-mono">
                  {service.descriptionFull}
                </p>

                <div class="grid sm:grid-cols-2 gap-4 mb-10">
                  {service.features.map((feature) => (
                    <div class="flex items-center gap-2">
                      <svg
                        class="w-5 h-5 text-success shrink-0"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                        stroke-width="2"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
                        />
                      </svg>
                      <span class="text-ivory/70">{feature}</span>
                    </div>
                  ))}
                </div>

                <Button href="/contact" variant="secondary" icon="arrow-right">
                  Hablemos de tu proyecto
                </Button>
              </div>

              <div class={`relative ${!isEven ? "lg:order-1" : "lg:order-2"}`}>
                <div class="absolute inset-0 bg-primary rounded-3xl blur-3xl opacity-20 -z-10 group-hover:opacity-40 transition-opacity duration-700" />
                <div class="overflow-hidden rounded-3xl border border-primary/10 shadow-2xl">
                  <Image
                    src={service.image}
                    alt={service.title}
                    loading={service.loading}
                    class="w-full object-cover aspect-video lg:aspect-square transform group-hover:scale-105 transition-transform duration-700 ease-out"
                  />
                </div>
              </div>
            </div>
          </section>
        );
      })
    }
  </div>
</main>

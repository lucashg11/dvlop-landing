---
import { ICONS } from "../../data/icons";
import IconBox from "../ui/IconBox.astro";

export interface Value {
    title: string;
    description: string;
    icon: string;
}

export interface Props {
    values: Value[];
}
const { values } = Astro.props;
---

<section class="mb-32 bg-surface border-y border-primary/10 py-24 reveal">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center max-w-3xl mx-auto mb-16">
            <h2 class="text-3xl md:text-5xl font-bold mb-4 reveal font-heading">
                Nuestros Valores Fundamentales
            </h2>
            <p class="text-muted text-lg">
                Los principios que guían nuestras decisiones técnicas, nuestros
                diseños y cómo tratamos a nuestros socios.
            </p>
        </div>

        <div class="grid md:grid-cols-2 gap-8">
            {
                values.map((value) => (
                    <div class="bg-void p-8 rounded-2xl border border-primary/10 flex gap-6 group hover:border-accent/30 transition-colors">
                        <IconBox icon={value.icon} size="lg" />
                        <div>
                            <h3 class="text-xl font-bold mb-3 font-heading">
                                {value.title}
                            </h3>
                            <p class="text-muted leading-relaxed font-mono">
                                {value.description}
                            </p>
                        </div>
                    </div>
                ))
            }
        </div>
    </div>
</section>

---
import { ArrowUpRight } from "@lucide/astro";
import { Image } from "astro:assets";
import ecommerceReplatformingImg from "../assets/images/e-commerce-replatforming.avif";
import fintechDashboardImg from "../assets/images/fintech-dashboard.avif";
import corporateIdentityImg from "../assets/images/corporate-identity.avif";
import healthcarePortalImg from "../assets/images/health-care-portal.avif";

const projects = [
    {
        id: "ecommerce-replatforming",
        title: "Rediseño E-Commerce",
        category: "Desarrollo Web",
        image: ecommerceReplatformingImg,
        link: "/work/#ecommerce-replatforming",
        loading: "lazy",
    },
    {
        id: "fintech-dashboard",
        title: "Fintech Dashboard",
        category: "Diseño UI/UX",
        image: fintechDashboardImg,
        link: "/work/#fintech-dashboard",
        loading: "lazy",
    },
    {
        id: "corporate-identity",
        title: "Identidad Corporativa",
        category: "Branding",
        image: corporateIdentityImg,
        link: "/work/#corporate-identity",
        loading: "lazy",
    },
    {
        id: "healthcare-portal",
        title: "Portal de Salud",
        category: "Aplicación Web",
        image: healthcarePortalImg,
        link: "/work/#healthcare-portal",
        loading: "lazy",
    },
];
---

<section id="work" class="py-24 bg-slate-900 border-t border-slate-800 reveal">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div
            class="flex flex-col md:flex-row md:items-end justify-between mb-16 gap-6"
        >
            <div class="max-w-2xl">
                <div
                    class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-indigo-500/10 border border-indigo-500/20 text-indigo-400 text-sm font-semibold tracking-wide uppercase mb-6"
                >
                    Nuestros Trabajos
                </div>
                <h2
                    class="text-3xl md:text-5xl font-bold reveal"
                    transition:name="work-title"
                >
                    Entregamos <span
                        class="text-transparent bg-clip-text bg-linear-to-r from-primary to-accent"
                        >Experiencias</span
                    >
                </h2>
            </div>
            <a
                href="/work"
                class="inline-flex items-center gap-2 text-slate-300 hover:text-white font-medium transition-colors group"
            >
                Más proyectos
                <ArrowUpRight
                    class="w-5 h-5 text-indigo-400 group-hover:translate-x-1 group-hover:-translate-y-1 transition-transform"
                />
            </a>
        </div>

        <div class="grid md:grid-cols-2 gap-8 lg:gap-12">
            {
                projects.map((project) => (
                    <a
                        href={project.link}
                        class="group block relative rounded-3xl overflow-hidden focus:outline-none focus:ring-4 focus:ring-indigo-500/50"
                    >
                        <div class="aspect-4/3 overflow-hidden relative">
                            <div class="absolute inset-0 bg-slate-900/20 group-hover:bg-transparent transition-colors z-10 duration-500" />
                            <Image
                                src={project.image}
                                alt={project.title}
                                loading={project.loading as "eager" | "lazy"}
                                class="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-700 ease-out"
                                transition:name={`project-image-${project.id}`}
                            />
                        </div>
                        <div class="absolute bottom-0 left-0 right-0 p-6 sm:p-8 bg-linear-to-t from-slate-950 via-slate-950/80 to-transparent z-20 translate-y-4 group-hover:translate-y-0 transition-transform duration-300">
                            <div class="flex items-center justify-between">
                                <div>
                                    <p class="text-indigo-500 font-medium mb-2 text-sm">
                                        {project.category}
                                    </p>
                                    <h3 class="text-2xl font-bold text-white group-hover:text-indigo-200 transition-colors">
                                        {project.title}
                                    </h3>
                                </div>
                                <div class="w-12 h-12 rounded-full bg-primary flex items-center justify-center opacity-0 group-hover:opacity-100 transform scale-50 group-hover:scale-100 transition-all duration-300">
                                    <ArrowUpRight class="w-6 h-6 text-white" />
                                </div>
                            </div>
                        </div>
                    </a>
                ))
            }
        </div>
    </div>
</section>

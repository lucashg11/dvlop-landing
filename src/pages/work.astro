---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import CTA from '../components/CTA.astro';
import { Clock, Target, CircleCheck } from "@lucide/astro";

const projects = [
    {
        id: "ecommerce-replatforming",
        title: "Rediseño E-Commerce",
        category: "Web Development",
        image: ecommerceReplatformingImg,
        timeline: "1 año",
        problem: "El cliente estaba atrapado en una plataforma monolítica heredada que causaba tiempos de carga de página de más de 5 segundos, lo que resultaba en una tasa de abandono de carritos desastrosamente alta y una mala clasificación en SEO.",
        solution: [
            "Migramos todo el catálogo a una arquitectura Headless Shopify.",
            "Construimos un frontend ultrarrápido usando Next.js y Tailwind CSS.",
            "Implementamos edge-caching resultando en tiempos de carga inferiores a un segundo.",
            "Integramos un CMS robusto para que el equipo de marketing gestionara el contenido libremente."
        ],
        results: "Las tasas de conversión aumentaron un 42% y la tasa de rebote del tráfico móvil disminuyó un 60% en el primer mes.",
        loading: "eager"
    },
    {
        id: "fintech-dashboard",
        title: "Fintech Dashboard",
        category: "UI/UX Design",
        image: fintechDashboardImg,
        timeline: "2 Meses",
        problem: "Una startup fintech prometedora tenía un backend potente pero su interfaz de usuario era intimidante, estaba desordenada y causaba una gran deserción entre los usuarios no técnicos.",
        solution: [
            "Realizamos una investigación exhaustiva de usuarios para comprender los puntos débiles.",
            "Rediseñamos todo el flujo de usuario para priorizar las acciones críticas.",
            "Creamos un sistema de diseño escalable usando Figma & Tailwind CSS.",
            "Implementamos modo oscuro y diseños de widgets personalizables."
        ],
        results: "El tiempo de participación del usuario aumentó un 35% y los tickets de soporte al cliente relacionados con la confusión de la interfaz de usuario se redujeron a casi cero.",
        loading: "lazy"
    },
    {
        id: "corporate-identity",
        title: "Identidad Corporativa",
        category: "Branding",
        image: corporateIdentityImg,
        timeline: "2 Meses",
        problem: "Una empresa B2B tradicional necesitaba modernizar su lenguaje visual para atraer clientes empresariales más jóvenes sin alienar a su base de clientes leales.",
        solution: [
            "Refinamos el imagotipo para que luzca impactante en formatos digitales.",
            "Desarrollamos una paleta de colores y un sistema tipográfico modernos y accesibles.",
            "Creamos guías de marca completas para los equipos de marketing.",
            "Diseñamos y desarrollamos una página de aterrizaje cohesiva para lanzar la marca."
        ],
        results: "The rebrand contributed to a 20% increase in inbound enterprise leads in Q3.",
        loading: "lazy"
    },
    {
        id: "healthcare-portal",
        title: "Portal de Salud",
        category: "Web App",
        image: healthcarePortalImg,
        timeline: "4 Meses",
        problem: "Los pacientes no podían acceder a sus registros sin problemas, lo que provocaba líneas telefónicas saturadas y una enorme carga administrativa para la clínica.",
        solution: [
            "Construimos un panel de control seguro y compatible con HIPAA para pacientes.",
            "Integramos puentes API con su software médico local heredado existente.",
            "Desarrollamos reservas de citas autoservicio y descargas de documentos.",
            "Garantizamos cifrado de extremo a extremo estricto y cumplimiento normativo."
        ],
        results: "El volumen de llamadas administrativas se redujo en un 55%, ahorrando miles de horas humanas al año.",
        loading: "lazy"
    }
];
import Footer from '../components/Footer.astro';
import { Image } from 'astro:assets';
import ecommerceReplatformingImg from "../assets/images/e-commerce-replatforming.avif";
import fintechDashboardImg from "../assets/images/fintech-dashboard.avif";
import corporateIdentityImg from "../assets/images/corporate-identity.avif";
import healthcarePortalImg from "../assets/images/health-care-portal.avif";
---

<Layout title="Our Work - DVLOP Premium Web Agency">
    <Header />
    
    <main class="pt-32 pb-24">
        <!-- Header -->
        <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center mb-24 reveal">
            <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-indigo-500/10 border border-indigo-500/20 text-accent text-sm font-semibold tracking-wide uppercase mb-6">
                Portfolio
            </div>
            <h1 class="text-5xl md:text-7xl font-extrabold mb-6 reveal" transition:name="work-title">
                Featured <span class="bg-clip-text bg-linear-to-r from-primary to-accent text-transparent">Projects</span>
            </h1>
            <p class="text-xl text-light/70 max-w-3xl mx-auto">
                Explore our recent collaborations. We break down the challenges our clients faced and exactly how we engineered solutions for them.
            </p>
        </section>

        <!-- Projects Feed -->
        <div class="space-y-32">
            {projects.map((project, index) => (
                <section id={project.id} class="scroll-mt-40 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 group reveal">
                    <div class="bg-slate-900 border border-slate-800 rounded-3xl overflow-hidden p-8 lg:p-12">
                        <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-start">
                            
                            <!-- Project Details -->
                            <div class="order-2 lg:order-1">
                                <div class="flex items-center gap-4 mb-6">
                                    <span class="text-accent font-medium uppercase tracking-wider text-sm">{project.category}</span>
                                    <span class="w-1.5 h-1.5 rounded-full bg-slate-700"></span>
                                    <div class="flex items-center gap-2 text-slate-400 text-sm font-medium">
                                        <Clock class="w-4 h-4" />
                                        {project.timeline}
                                    </div>
                                </div>
                                
                                <h2 class="text-3xl md:text-4xl font-bold text-white mb-8 group-hover:text-primary transition-colors reveal">
                                    {project.title}
                                </h2>
                                
                                <div class="mb-8">
                                    <h3 class="flex items-center gap-2 text-lg font-bold text-white mb-3">
                                        <Target class="w-5 h-5 text-red-400" />
                                        The Problem
                                    </h3>
                                    <p class="text-light/80 leading-relaxed">
                                        {project.problem}
                                    </p>
                                </div>
                                
                                <div class="mb-8">
                                    <h3 class="flex items-center gap-2 text-lg font-bold text-white mb-4">
                                        <CircleCheck class="w-5 h-5 text-emerald-400" />
                                        Our Solution
                                    </h3>
                                    <ul class="space-y-3">
                                        {project.solution.map(item => (
                                            <li class="flex items-start gap-3">
                                                <span class="w-1.5 h-1.5 rounded-full bg-primary mt-2 shrink-0"></span>
                                                <span class="text-light/80">{item}</span>
                                            </li>
                                        ))}
                                    </ul>
                                </div>
                                
                                <div class="p-6 bg-primary/10 border border-primary/20 rounded-2xl">
                                    <h4 class="text-primary font-bold mb-2">The Outcome</h4>
                                    <p class="text-white font-medium">{project.results}</p>
                                </div>
                            </div>
                            
                            <!-- Project Image -->
                            <div class="order-1 lg:order-2 relative aspect-video lg:aspect-4/3 rounded-2xl overflow-hidden shadow-2xl border border-slate-800">
                                <Image src={project.image}
                                    alt={project.title}
                                    loading={project.loading as "eager" | "lazy"}
                                    class="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-700 ease-out"
                                    transition:name={`project-image-${project.id}`}
                                />
                                <div class="absolute inset-0 border border-white/10 rounded-2xl z-10 pointer-events-none"></div>
                            </div>
                            
                        </div>
                    </div>
                </section>
            ))}
        </div>
        
        <CTA />
    </main>
    
    <Footer />
</Layout>

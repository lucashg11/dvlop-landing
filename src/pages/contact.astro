---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import ContactForm from "../components/Contact.astro";
import Footer from "../components/Footer.astro";
---

<Layout title="Contacto - LUCAS <DEV/>">
  <Header />

  <main class="pt-32 pb-24">
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center mb-12">
      <h1
        class="text-5xl md:text-6xl font-extrabold mb-6 reveal font-display"
        transition:name="contact-title"
      >
        ¿Necesitas un sitio que <span class="text-primary"
          >traiga clientes?</span
        >
      </h1>
      <p class="text-xl text-muted max-w-3xl mx-auto reveal">
        Cuéntame qué negocio tenés, qué problemas tiene, y juntos pensamos si
        una web te sirve. Te contesto en menos de 24 horas.
      </p>
    </section>

    <ContactForm />
  </main>

  <Footer />
</Layout>

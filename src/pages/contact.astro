---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import ContactForm from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Contact Us - DVLOP Premium Web Agency">
    <Header />
    
    <main class="pt-32 pb-24">
        <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center mb-12">
            <h1 class="text-5xl md:text-6xl font-extrabold mb-6 reveal" transition:name="contact-title">
                Get in <span class="text-primary">Touch</span>
            </h1>
            <p class="text-xl text-slate-400 max-w-3xl mx-auto reveal">
                We're ready to help you build your digital future. Reach out today and let's start the conversation.
            </p>
        </section>
        
        <!-- We reuse the Contact form component which handles all the visual styling and logic -->
        <ContactForm />
    </main>
    
    <Footer />
</Layout>

---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import CTA from "../components/CTA.astro";
import Footer from "../components/Footer.astro";
import aboutImg from "../assets/images/about-page.avif";
import teamMember1 from "../assets/images/team-avatar-1.avif";
import teamMember2 from "../assets/images/team-avatar-2.avif";
import teamMember3 from "../assets/images/team-avatar-3.avif";
import teamMember4 from "../assets/images/team-avatar-4.avif";
import { Image } from "astro:assets";
import { Target, Users, Zap, Award } from "@lucide/astro";

const values = [
    {
        title: "Client-Centric Approach",
        description:
            "Your business goals are our primary directive. We don't just build software; we build solutions that solve your specific operational challenges.",
        icon: Target,
    },
    {
        title: "Uncompromising Quality",
        description:
            "We obsess over the details. Clean architecture, pixel-perfect design, and sub-second load times are standard in every project we deliver.",
        icon: Award,
    },
    {
        title: "Lightning Execution",
        description:
            "We work fast without cutting corners. Our agile methodologies and modern tech stack allow us to iterate rapidly and deliver results ahead of schedule.",
        icon: Zap,
    },
    {
        title: "Radical Transparency",
        description:
            "No black boxes. You'll have constant insight into our process, progress, and rationale behind every technical decision we make.",
        icon: Users,
    },
];

const team = [
    {
        name: "Alex Rivera",
        role: "Founder, Technical Director",
        image: teamMember1,
        loading: "lazy",
    },
    {
        name: "Sarah Jenkins",
        role: "Lead UI/UX Designer",
        image: teamMember2,
        loading: "lazy",
    },
    {
        name: "David Chen",
        role: "Senior Full-Stack Engineer",
        image: teamMember3,
        loading: "lazy",
    },
    {
        name: "Maya Patel",
        role: "Performance & SEO Lead",
        image: teamMember4,
        loading: "lazy",
    },
];
---

<Layout title="About Us - DVLOP Premium Web Agency">
    <Header />

    <main class="pt-32 pb-24">
        <!-- Hero Section -->
        <section
            class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center mb-24 lg:mb-32 reveal"
        >
            <div
                class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-indigo-500/10 border border-indigo-500/20 text-accent text-sm font-semibold tracking-wide uppercase mb-6"
            >
                Who We Are
            </div>
            <h1
                class="text-5xl md:text-7xl font-extrabold mb-8 reveal"
                transition:name="about-title"
            >
                Building the <span
                    class="text-transparent bg-clip-text bg-linear-to-r from-indigo-400 to-cyan-400"
                    >Standard</span
                ><br class="hidden md:block" /> for the Modern Web
            </h1>
            <p class="text-xl text-slate-400 max-w-3xl mx-auto leading-relaxed">
                We are a boutique digital product agency born out of a desire to
                rid the web of slow, uninspiring websites. We combine strategic
                thinking with elite engineering to scale businesses.
            </p>
        </section>

        <!-- Our Story -->
        <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-32 reveal">
            <div class="grid lg:grid-cols-2 gap-16 items-center">
                <div class="relative">
                    <div
                        class="absolute inset-0 bg-indigo-600 rounded-3xl blur-3xl opacity-20 -z-10"
                    >
                    </div>
                    <Image
                        src={aboutImg}
                        alt="Our office collaboration"
                        loading="eager"
                        class="rounded-3xl border border-slate-800 shadow-2xl w-full object-cover aspect-square lg:aspect-4/5"
                    />
                </div>

                <div class="lg:pl-10">
                    <h2 class="text-3xl md:text-5xl font-bold mb-8 reveal">
                        Our Story
                    </h2>
                    <div
                        class="space-y-6 text-lg text-slate-400 leading-relaxed"
                    >
                        <p>
                            DVLOP was founded in 2018 when a group of senior
                            engineers and interface designers decided they had
                            enough of the "industry standard" software agencies
                            pumping out monolithic, slow-loading templates.
                        </p>
                        <p>
                            We recognized early on that the future of the web
                            belonged to headless architectures and decoupled
                            frontends. By adopting cutting-edge technologies
                            early, we began delivering digital experiences that
                            dramatically outperformed our clients' deepest
                            competitors.
                        </p>
                        <p>
                            Today, we are a tight-knit collective operating
                            globally. We intentionally remain a boutique
                            agency—taking on a limited number of projects
                            simultaneously so we can integrate deeply with our
                            clients' teams and obsess over the quality of our
                            code and design.
                        </p>
                    </div>

                    <div
                        class="grid grid-cols-2 gap-8 mt-12 pt-12 border-t border-slate-800"
                    >
                        <div>
                            <div
                                class="text-4xl font-extrabold text-white mb-2"
                            >
                                200+
                            </div>
                            <div class="text-white font-medium">
                                Projects Shipped
                            </div>
                        </div>
                        <div>
                            <div
                                class="text-4xl font-extrabold text-white mb-2"
                            >
                                99%
                            </div>
                            <div class="text-white font-medium">
                                Client Retention
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Core Values -->
        <section
            class="mb-32 bg-slate-900 border-y border-slate-800 py-24 reveal"
        >
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="text-center max-w-3xl mx-auto mb-16">
                    <h2 class="text-3xl md:text-5xl font-bold mb-4 reveal">
                        Our Core Values
                    </h2>
                    <p class="text-slate-400 text-lg">
                        The principles that guide our technical decisions, our
                        designs, and how we treat our partners.
                    </p>
                </div>

                <div class="grid md:grid-cols-2 gap-8">
                    {
                        values.map((value) => {
                            const Icon = value.icon;
                            return (
                                <div class="bg-slate-950 p-8 rounded-2xl border border-slate-800/50 flex gap-6 group hover:border-indigo-500/50 transition-colors">
                                    <div class="w-14 h-14 bg-indigo-500/10 rounded-xl flex items-center justify-center shrink-0 group-hover:bg-indigo-500/20 transition-colors">
                                        <Icon class="w-7 h-7 text-indigo-400" />
                                    </div>
                                    <div>
                                        <h3 class="text-xl font-bold mb-3">
                                            {value.title}
                                        </h3>
                                        <p class="text-slate-400 leading-relaxed">
                                            {value.description}
                                        </p>
                                    </div>
                                </div>
                            );
                        })
                    }
                </div>
            </div>
        </section>

        <!-- The Team -->
        <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-24 reveal">
            <div class="text-center max-w-3xl mx-auto mb-16">
                <h2 class="text-3xl md:text-5xl font-bold mb-4 reveal">
                    Meet the Team
                </h2>
                <p class="text-slate-400 text-lg">
                    The senior talent responsible for architecting and designing
                    your digital presence.
                </p>
            </div>

            <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-8">
                {
                    team.map((member) => (
                        <div class="group">
                            <div class="relative overflow-hidden mb-6 rounded-2xl aspect-3/4">
                                <div class="absolute inset-0 bg-slate-900/20 group-hover:bg-transparent transition-colors z-10" />
                                <Image
                                    src={member.image}
                                    alt={member.name}
                                    inferSize={true}
                                    loading={member.loading as "eager" | "lazy"}
                                    class="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-700 ease-out grayscale group-hover:grayscale-0"
                                />
                            </div>
                            <h3 class="text-xl font-bold mb-1">
                                {member.name}
                            </h3>
                            <p class="text-indigo-400 font-medium">
                                {member.role}
                            </p>
                        </div>
                    ))
                }
            </div>
        </section>

        <CTA />
    </main>

    <Footer />
</Layout>
